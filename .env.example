# EdgeIQ Labs Security Report Generator — Environment Configuration

# Scan Input Directory (where EdgeIQ tools drop their JSON output)
SCAN_INPUT_DIR=./input/scans

# Output Directory
OUTPUT_DIR=./output

# SMTP Delivery
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=security@edgeiq.io
SMTP_TO=recipient@example.com,recipient2@example.com

# Telegram Delivery
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=@your_channel_or_chat_id

# EdgeIQ Tool Paths (optional — leave blank to skip subprocess calls)
EDGEIQ_XSS_SCANNER=
EDGEIQ_NETWORK_SCANNER=
EDGEIQ_SSL_WATCHER=

# Report Defaults
REPORT_TITLE=Monthly Security Report
THROTTLE_MS=1000